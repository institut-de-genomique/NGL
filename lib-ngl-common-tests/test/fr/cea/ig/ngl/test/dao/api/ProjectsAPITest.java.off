package fr.cea.ig.ngl.test.dao.api;

import static fr.cea.ig.ngl.test.resource.RConstant.USER;
import static fr.cea.ig.play.test.TestAssertions.assertOne;
import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertNotEquals;
import static org.junit.Assert.assertNotNull;
import static org.junit.Assert.assertNull;

import java.util.function.Consumer;

import javax.inject.Singleton;

import org.junit.Test;

import fr.cea.ig.ngl.dao.projects.ProjectsAPI;
import fr.cea.ig.ngl.support.ListFormWrapper;
import fr.cea.ig.ngl.test.dao.api.factory.QueryMode;
import fr.cea.ig.ngl.test.dao.api.factory.TestProjectFactory;
import fr.cea.ig.ngl.test.resource.RApplication;
import fr.cea.ig.ngl.test.resource.RProject;
import fr.cea.ig.test.APIRef;
import fr.cea.ig.util.function.CC1;
import fr.cea.ig.util.function.CC2;
import fr.cea.ig.util.function.T;
import models.laboratory.project.instance.Project;

/**
 * Test {@link ProjectsAPI} methods.
 * 
 * @author ajosso
 *
 */
@Singleton  
public class ProjectsAPITest {

	private static final play.Logger.ALogger logger = play.Logger.of(ProjectsAPITest.class);
	
	private final APIRef<ProjectsAPI> api = APIRef.project;

	// Test data as required by the tests
//	private static final CC2<Project,Project> testData = 
//			TUResources.contextResource
//			.nest2((context) 					  -> TUResources.createFullProject)
//			.cc2(  (context, refProject, project) -> T.t2(refProject, project));
	
//	private static final CC2<Project,Project> testData = 
//			RApplication.app
//			.and2(RProject.createProjectRaw)
//			.cc2 ((context, refProject, project) -> T.t2(refProject, project));
	
	/**
	 * Test data constructor.
	 * @param cc context CC
	 * @return   test data
	 */
	private static final <A> CC2<Project, Project> buildTestData(CC1<A> cc) {
		return cc.and2(RProject.createProjectRaw)
				 .cc2 ((ctx, p0, p1) -> T.t2(p0,p1));
	}
	
	/**
	 * Standard test data.
	 */
	private static final CC2<Project, Project> testData = buildTestData(RApplication.app);
	
	/**
	 * Debug mode test data.
	 */
	@SuppressWarnings("unused")
	private static final CC2<Project, Project> testDataLog = buildTestData(RApplication.appLog);
			
	@Test
	public void createTest() throws Exception {
		logger.debug("running test 'createTest'");
		testData.accept((refProject,data) -> {
			logger.debug("createTest - begin");
			assertNotNull(data);
			logger.debug("project ID: " + data._id);
			assertEquals(refProject.code,                     data.code);
			assertEquals(refProject.name,                     data.name);
			assertEquals(refProject.typeCode,                 data.typeCode);
			assertEquals(refProject.categoryCode,             data.categoryCode);
			assertEquals(refProject.description,              data.description);
			assertEquals(refProject.umbrellaProjectCode,      data.umbrellaProjectCode);
			assertEquals(refProject.lastSampleCode,           data.lastSampleCode);
			assertEquals(refProject.nbCharactersInSampleCode, data.nbCharactersInSampleCode);
			assertEquals(refProject.state.code,               data.state.code);
			assertEquals(refProject.state.user,               data.state.user);
			assertEquals(refProject.authorizedUsers,          data.authorizedUsers);
			assertEquals(refProject.comments.size(),          data.comments.size());
			logger.debug("createTest - end");
		});
	}

	@Test
	public void deleteTest() throws Exception {
		logger.debug("running test 'deleteTest'");
		testData.accept((__,project) -> {
			logger.debug("deleteTest - begin");
			String code = project.getCode();
			api.get().delete(code);
			Project proj = api.get().get(code);
			assertNull(proj);
			logger.debug("deleteTest - end");
		});
	}

	@Test
	public void getTest() throws Exception {
		logger.debug("running test 'getTest'");
		testData.accept((refProject,data) -> {
			logger.debug("getTest - begin");
			Project proj = api.get().get(refProject.code);
			assertNotNull(proj);
			assertEquals("data.id == proj.id", data.get_id(), proj.get_id());
			assertEquals("refProject.code == proj.code", refProject.getCode(), proj.getCode());
			logger.debug("getTest - end");
		});
	}

	@Test
	public void listTest() throws Exception {
		testData.accept((refProject,data) -> {
			//---------- default mode ----------
			logger.debug("default mode");
			ListFormWrapper<Project> wrapper = TestProjectFactory.wrapper(refProject.code);

			Consumer<Project> projectAssertions = 
					p -> {
						  assertEquals(refProject.code, p.code);
						  assertEquals(refProject.categoryCode, p.categoryCode);
					};
			
			assertOne(api.get().listObjects(wrapper), projectAssertions);
			
			//---------- reporting mode----------
			logger.debug("reporting mode");
			wrapper = TestProjectFactory.wrapper(refProject.code, QueryMode.REPORTING, null);
			
			assertOne(api.get().listObjects(wrapper), projectAssertions);
		});
	}
	
}
